<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Kenya Tools Hub</title>
  <link rel="stylesheet" href="style.css">
</head>
<body>

  <h1>🇰🇪 Kenya Tools Hub</h1>

  <nav>
    <button onclick="showTool('helb')">HELB Calculator</button>
    <button onclick="showTool('grade')">Grade Calculator</button>
    <button onclick="showTool('invoice')">Invoice Generator</button>
  </nav>

  <!-- HELB -->
  <section id="helb" class="tool">
    <h2>HELB Loan Calculator</h2>
    <input type="number" id="loan" placeholder="Loan Amount">
    <input type="number" id="years" placeholder="Repayment Years">
    <button onclick="calculateHELB()">Calculate</button>
    <p id="helbResult"></p>
  </section>

  <!-- Grade -->
  <section id="grade" class="tool" style="display:none;">
    <h2>Grade Calculator</h2>
    <input type="number" id="marks" placeholder="Enter Marks">
    <button onclick="calculateGrade()">Calculate</button>
    <p id="gradeResult"></p>
  </section>

  <!-- Invoice -->
  <section id="invoice" class="tool" style="display:none;">
    <h2>Invoice Generator</h2>
    <input type="text" id="item" placeholder="Item Name">
    <input type="number" id="price" placeholder="Price">
    <button onclick="generateInvoice()">Add Item</button>

    <ul id="invoiceList"></ul>
    <h3 id="total"></h3>
  </section>

  <script src="script.js"></script>
</body>
</html>
